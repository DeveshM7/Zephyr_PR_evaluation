+static void process_and_validate(bool backend2_enable, bool panic)
+{
+	if (!panic) {
+		flush_log();
+	}
+
+	mock_log_backend_validate(&backend1, panic);
+
+	if (backend2_enable) {
+		mock_log_backend_validate(&backend2, panic);
+	}
+}
